# Test-runner secrets template — commit this file, NOT .env.test.local
#
# Copy to .env.test.local and fill in real values:
#   cp .env.test.local.example .env.test.local
#
# Then run tests with:
#   docker compose -f docker-compose.yml -f docker-compose.test.yml \
#     --env-file .env.test.local run --rm test-runner

# Generate by logging into the frontend; copy from localStorage 'access_token'
TEST_API_TOKEN=

# Discord guild ID the token has owner/admin access to
TEST_GUILD_ID=

# A Discord user ID to add/remove as authorized user (must NOT be the guild owner)
TEST_USER_ID=

# A Discord role ID that exists in TEST_GUILD_ID
TEST_ROLE_ID=
